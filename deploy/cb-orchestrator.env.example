# upstream
UPSTREAM_MODE=github_release
UPSTREAM_REPO_ROOT=/home/hermes/workspace/CB-Qlib-Infra
UPSTREAM_PYTHON_BIN=/home/hermes/workspace/CB-Qlib-Infra/.venv/bin/python
UPSTREAM_STATE_FILE=/home/hermes/workspace/cb-qlib-data/state/latest.json
UPSTREAM_ENV_FILE=/home/hermes/.config/cb-qlib/cb-qlib.env
UPSTREAM_LOOKBACK_TRADE_DAYS=7
UPSTREAM_REPAIR_TRADE_DAYS=20

# github release consumer
GITHUB_RELEASE_TOKEN=github_pat_xxx
GITHUB_RELEASE_REPO=HiJean99/CB-Qlib-Infra
GITHUB_RELEASE_TAG=cb-data-latest
GITHUB_RELEASE_ASSET_NAME=cb-qlib-data-latest.tar.zst
RELEASE_INSTALL_DIR=/home/hermes/local_data/qlib_data
RELEASE_WORK_DIR=/home/hermes/cb_online_runtime/local_state/orchestrator/release_tmp
RELEASE_POLL_INTERVAL_MINUTES=15
RELEASE_WINDOW_END_HOUR=4

# provider / calendar
PROVIDER_URI=/home/hermes/local_data/qlib_data
TRADE_CALENDAR_PATH=/home/hermes/local_data/qlib_data/calendars/day.txt

# runtime
RUNTIME_REPO_ROOT=/home/hermes/cb_online_runtime
PACKS_ROOT=/home/hermes/cb_online_runtime/local_assets/packs
MODEL_ROOT=/home/hermes/cb_online_runtime/local_state/models
BUILD_ROOT=/home/hermes/cb_online_runtime/local_state/builds
PREDICTION_ROOT=/home/hermes/cb_online_runtime/local_state/predictions
LOG_ROOT=/home/hermes/cb_online_runtime/local_state/logs
# optional runtime entry overrides
# RUNTIME_PYTHON_BIN=/home/hermes/miniconda3/envs/q_lab/bin/python
# RUNTIME_PYTHONPATH=/home/hermes/cb_online_runtime/src
# RUNTIME_TRAIN_BIN=/home/hermes/venvs/cb_online_runtime/bin/cb-online-train
# RUNTIME_PREDICT_BIN=/home/hermes/venvs/cb_online_runtime/bin/cb-online-predict

# orchestrator
ORCH_STATE_ROOT=/home/hermes/cb_online_runtime/local_state/orchestrator
ORCH_STRATEGIES=cb_batch_15,cb_batch_27
TRAIN_START=2018-01-01
ROLLING_VALID_MONTHS=12
MODEL_NUM_THREADS=2
TOP_COUNT=10
PLAN_INPUT_ROOT=/home/hermes/cb_online_runtime/local_state/orchestrator/plan_inputs
PLAN_OUTPUT_ROOT=/home/hermes/cb_online_runtime/local_state/orchestrator/next_trade_plans
NEXT_TRADE_TOP_N=6
NEXT_TRADE_MAX_DROP=3

# optional mail passthrough
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=xxx@qq.com
# SMTP_PASSWORD=app_password
# EMAIL_TO=first@example.com,second@example.com
# EMAIL_FROM=xxx@qq.com
# EMAIL_SUBJECT_PREFIX=[cb-online-runtime]
